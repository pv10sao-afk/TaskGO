<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical">

    <!-- App name + icon row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_today"
            android:tint="#7B9FFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DayFlow"
            android:textColor="#7B9FFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Task count -->
    <TextView
        android:id="@+id/widget_task_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 задач"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:fontFamily="sans-serif-black" />

    <!-- Next task label -->
    <TextView
        android:id="@+id/widget_next_task"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Немає завдань на сьогодні"
        android:textColor="#AAAACC"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="4dp" />

    <!-- Deadline row -->
    <TextView
        android:id="@+id/widget_deadline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#7B9FFF"
        android:textSize="11sp"
        android:layout_marginTop="4dp" />

</LinearLayout>
